{
  "name": "foundation",
  "private": "true",
  "scripts": {
    "development": "mix",
    "watch": "mix watch",
    "watch-poll": "mix watch -- --watch-options-poll=1000",
    "hot": "mix watch --hot",
    "production": "mix --production",
    "lint": "eslint ./",
    "lint:fix": "eslint --fix ./",
    "stylelint": "stylelint ./resources/sass/**/*.scss",
    "stylelint:fix": "stylelint --fix ./resources/sass/**/*.scss",
    "prettier": "prettier \"**/*.js\" --write --ignore-path .eslintignore"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/wearealloy/foundation.git"
  },
  "keywords": [
    "craft cms",
    "laravel-mix"
  ],
  "author": "Anuar Reyes <anuar@hey.com>",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/wearealloy/foundation/issues"
  },
  "homepage": "https://github.com/wearealloy/foundation#readme",
  "devDependencies": {
    "@babel/eslint-parser": "^7.19.1",
    "browser-sync": "^2.27.10",
    "browser-sync-webpack-plugin": "^2.3.0",
    "eslint": "^8.25.0",
    "eslint-config-airbnb-base": "^15.0.0",
    "eslint-config-prettier": "^8.5.0",
    "eslint-plugin-import": "^2.26.0",
    "husky": "^8.0.1",
    "laravel-mix": "^6.0.49",
    "laravel-mix-criticalcss": "^1.0.2",
    "laravel-mix-purgecss": "^6.0.0",
    "prettier": "^2.7.1",
    "resolve-url-loader": "^5.0.0",
    "sass": "^1.55.0",
    "sass-loader": "^13.1.0",
    "stylelint": "^14.13.0",
    "stylelint-config-prettier": "^9.0.3",
    "stylelint-config-prettier-scss": "^0.0.1",
    "stylelint-config-standard": "^28.0.0",
    "stylelint-config-standard-scss": "^5.0.0"
  },
  "dependencies": {
    "focus-visible": "^5.2.0"
  }
}
